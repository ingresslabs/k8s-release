#!/usr/bin/env bash
set -euo pipefail

usage() {
    cat <<'EOF'
Usage:
  k8s-release build <version> --component <name> --format <deb|rpm|deb,rpm>
  k8s-release verify-release <version> [--repo OWNER/REPO] [--dir DIR]
  k8s-release bundle <version> --airgap [--artifacts DIR] [--repos DIR] [--output FILE]
  k8s-release verify-bundle <bundle.tar> [--repo OWNER/REPO] [--online]
  k8s-release passport <version> [--artifacts DIR] [--repos DIR] [--output FILE]
  k8s-release prove <version> --host HOST [--previous VERSION]
  k8s-release version
  k8s-release components

Examples:
  k8s-release build v1.32.2 --component kubelet --format deb,rpm
  k8s-release build v3.5.9 --component etcd --format rpm
  k8s-release verify-release v1.32.2
  k8s-release bundle v1.32.2 --airgap
  k8s-release verify-bundle k8s-v1.32.2-airgap.tar
  k8s-release prove v1.32.2 --host Fourier --previous v1.32.1
EOF
}

components() {
    cat <<'EOF'
kube-proxy
kubelet
etcd
kube-scheduler
kube-controller-manager
kube-apiserver
kubectl
flannel
calico
certificates
EOF
}

repo_root=$(CDPATH= cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
cd "${repo_root}"

command=${1:-}
case "${command}" in
    components)
        components
        exit 0
        ;;
    verify-release)
        shift
        exec ./scripts/verify-release.sh "$@"
        ;;
    bundle)
        shift
        exec ./scripts/create-airgap-bundle.sh "$@"
        ;;
    verify-bundle)
        shift
        exec ./scripts/verify-bundle.sh "$@"
        ;;
    passport)
        shift
        exec ./scripts/generate-release-passport.sh "$@"
        ;;
    prove)
        shift
        exec ./scripts/prove-release.sh "$@"
        ;;
    version)
        cat VERSION
        exit 0
        ;;
    build)
        shift
        ;;
    -h|--help|help|"")
        usage
        exit 0
        ;;
    *)
        echo "ERROR: unknown command '${command}'."
        usage
        exit 1
        ;;
esac

version=${1:-}
if [ -z "${version}" ]; then
    echo "ERROR: build version is required."
    usage
    exit 1
fi
shift

component=
format=deb

while [ "$#" -gt 0 ]; do
    case "$1" in
        --component)
            component=${2:-}
            shift 2
            ;;
        --format)
            format=${2:-}
            shift 2
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        *)
            echo "ERROR: unknown argument '$1'."
            usage
            exit 1
            ;;
    esac
done

if [ -z "${component}" ]; then
    echo "ERROR: --component is required."
    exit 1
fi

case "${format}" in
    deb|rpm|all)
        package_type=${format}
        ;;
    deb,rpm|rpm,deb)
        package_type=all
        ;;
    *)
        echo "ERROR: unsupported --format '${format}'. Use deb, rpm, or deb,rpm."
        exit 1
        ;;
esac

case "${component}" in
    kube-proxy|kubelet|kube-scheduler|kube-controller-manager|kube-apiserver|kubectl)
        exec make "build-${component}" KUBE_VERSION="${version}" PACKAGE_TYPE="${package_type}"
        ;;
    etcd)
        exec make build-etcd ETCD_VERSION="${version}" PACKAGE_TYPE="${package_type}"
        ;;
    flannel)
        exec make build-flannel FLANNEL_VERSION="${version}" PACKAGE_TYPE="${package_type}"
        ;;
    calico)
        exec make build-calico CALICO_VERSION="${version}" PACKAGE_TYPE="${package_type}"
        ;;
    certificates)
        exec make build-certificates CERT_VERSION="${version#v}" PACKAGE_TYPE="${package_type}"
        ;;
    *)
        echo "ERROR: unsupported component '${component}'."
        components
        exit 1
        ;;
esac
